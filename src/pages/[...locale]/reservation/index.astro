---
import { actions } from 'astro:actions';
import Base from '@/layouts/Base.astro';
import { LOCALES, LOCALE_NAMES } from '@/i18n/config';
import { localizedPath, resolveLocale, useTranslations } from '@/i18n/utils';
import { bookableDates, freeSlotsForDate, isValidSlot, slotsForDate } from '@/lib/availability';
import { buildCalendar } from '@/lib/calendar';
import { PREFECTURES } from '@/lib/prefectures';
import { getActiveSlotStarts } from '@/db/queries';
import { formatDateLong, formatMonthYear, formatSlotLong } from '@/lib/datetime';

const locale = resolveLocale(Astro.params.locale);
if (!locale) return new Response('Not Found', { status: 404 });
const t = useTranslations(locale);

// If a booking was just submitted successfully, go to the confirmation page.
const result = Astro.getActionResult(actions.createBooking);
if (result && !result.error) {
	return Astro.redirect(localizedPath('/reservation/received', locale));
}

// Availability for the bookable window.
const dates = bookableDates();
const taken = dates.length
	? await getActiveSlotStarts(dates[0], dates[dates.length - 1])
	: new Set<string>();
const days = dates
	.map((date) => ({ date, slots: freeSlotsForDate(date, taken) }))
	.filter((d) => d.slots.length > 0);

// Calendar model: a month grid spanning the booking window; only dates that have
// free slots are clickable.
const availableDates = new Set(days.map((d) => d.date));
const months = dates.length ? buildCalendar(dates[0], dates[dates.length - 1], availableDates) : [];

// Weekday header, Monday-first, reusing the localized day names from the hours
// dictionary that every locale already provides.
const weekdayKeys = ['mon', 'tue', 'wed', 'thu', 'fri', 'sat', 'sun'] as const;

const reservationPath = localizedPath('/reservation', locale);

// The details form posts back to this page (not directly to the action) so we can
// render a review/confirmation step first. We read the submitted values here:
// `_step === 'edit'` means "go back and edit" (re-render the prefilled form),
// anything else is a request to show the review screen. Only a plain page POST is
// parsed — the final "Confirm" submit targets the action, whose body Astro has
// already consumed (and is reflected in `result`).
let posted: Record<string, string> | null = null;
if (Astro.request.method === 'POST' && !result) {
	const fd = await Astro.request.formData();
	posted = Object.fromEntries(
		[...fd.entries()].map(([k, v]) => [k, typeof v === 'string' ? v : '']),
	);
}
const wantsEdit = posted?._step === 'edit';
const wantsReview = posted !== null && !wantsEdit;

// The slot in play comes from the posted form (review/edit) or from ?slot=. It
// must still be valid and free for the form/review to render.
const slotParam = Astro.url.searchParams.get('slot');
const activeSlotStart = posted?.slotStart ?? slotParam ?? null;
const activeSlot =
	activeSlotStart && isValidSlot(activeSlotStart) && !taken.has(activeSlotStart)
		? (slotsForDate(activeSlotStart.slice(0, 10)).find((s) => s.start === activeSlotStart) ?? null)
		: null;

const showReview = Boolean(activeSlot && wantsReview);
const showForm = Boolean(activeSlot && !wantsReview);

// Field values to prefill the form / carry through the review round-trip. The
// keys below are exactly the inputs the createBooking action expects.
const fv = posted ?? {};
const FIELD_KEYS = [
	'slotStart', 'customerNumber', 'firstVisit', 'name', 'nameKana', 'gender',
	'dateOfBirth', 'email', 'phone', 'postalCode', 'prefecture', 'address', 'locale',
] as const;

// Human-readable rows for the review screen (reusing the form's field labels).
const dash = '—';
const reviewRows = activeSlot
	? [
			{ label: t('booking.form.customerNumber'), value: fv.customerNumber || dash },
			{
				label: t('booking.form.firstVisit'),
				value: fv.firstVisit === 'returning' ? t('booking.form.firstVisitReturning') : t('booking.form.firstVisitNew'),
			},
			{ label: t('booking.form.name'), value: fv.name || dash },
			{ label: t('booking.form.nameKana'), value: fv.nameKana || dash },
			{
				label: t('booking.form.gender'),
				value: fv.gender === 'male' ? t('booking.form.genderMale') : t('booking.form.genderFemale'),
			},
			{ label: t('booking.form.dateOfBirth'), value: fv.dateOfBirth || dash },
			{ label: t('booking.form.email'), value: fv.email || dash },
			{ label: t('booking.form.phone'), value: fv.phone || dash },
			{ label: t('booking.form.postalCode'), value: fv.postalCode || dash },
			{ label: t('booking.form.prefecture'), value: fv.prefecture || dash },
			{ label: t('booking.form.address'), value: fv.address || dash },
			{
				label: t('booking.form.language'),
				value: LOCALE_NAMES[fv.locale as keyof typeof LOCALE_NAMES] ?? fv.locale ?? dash,
			},
		]
	: [];

// A selected date (via ?date=) that has availability → reveal that day's slots.
const dateParam = Astro.url.searchParams.get('date');
const selectedDate = dateParam && availableDates.has(dateParam) ? dateParam : null;

const errorMsg = result?.error
	? result.error.code === 'CONFLICT'
		? t('booking.errors.slotTaken')
		: t('booking.errors.invalid')
	: posted && !activeSlot
		? t('booking.errors.slotTaken')
		: '';
---

<Base
	{locale}
	canonical="/reservation"
	title={t('booking.metaTitle')}
	description={t('booking.metaDescription')}
>
	<section>
		<h1 class="section-title">{t('booking.heading')}</h1>
		<p class="lead">{t('booking.intro')}</p>

		{errorMsg && <div class="error-banner">{errorMsg}</div>}

		{
			showReview ? (
				<div>
					<div class="callout" style="margin-bottom:24px">
						<strong>{t('booking.selectedSlot')}:</strong><br />
						{formatSlotLong(activeSlot!.start, locale)}
					</div>

					<h2 class="section-title">{t('booking.review.heading')}</h2>
					<p class="lead">{t('booking.review.intro')}</p>

					<table class="info-table" style="margin-bottom:24px">
						<tbody>
							{reviewRows.map((row) => (
								<tr>
									<th>{row.label}</th>
									<td>{row.value}</td>
								</tr>
							))}
						</tbody>
					</table>

					<div class="review-actions">
						{/* Confirm → submit to the action, which creates the booking. */}
						<form method="POST" action={actions.createBooking}>
							{FIELD_KEYS.map((k) => (
								<input type="hidden" name={k} value={fv[k] ?? ''} />
							))}
							<button class="btn btn-primary" type="submit">{t('booking.review.confirm')}</button>
						</form>
						{/* Edit → re-render the prefilled details form (no action). */}
						<form method="POST">
							{FIELD_KEYS.map((k) => (
								<input type="hidden" name={k} value={fv[k] ?? ''} />
							))}
							<input type="hidden" name="_step" value="edit" />
							<button class="btn btn-outline" type="submit">← {t('booking.review.edit')}</button>
						</form>
					</div>
				</div>
			) : showForm ? (
				<div>
					<div class="callout" style="margin-bottom:24px">
						<strong>{t('booking.selectedSlot')}:</strong><br />
						{formatSlotLong(activeSlot!.start, locale)}
						<br />
						{/* href returns to the chosen day (no-JS fallback); with JS the
						    script makes it use the browser Back button so the calendar
						    state and scroll position are restored without a reload. The
						    Back shortcut is skipped when we arrived here via an "edit"
						    POST (data-back="false") to avoid a form-resubmission prompt. */}
						<a
							class="change-slot"
							data-back={(!posted).toString()}
							href={`${reservationPath}?date=${activeSlot!.start.slice(0, 10)}`}
						>
							← {t('booking.changeSlot')}
						</a>
					</div>

					<h2 class="section-title">{t('booking.form.heading')}</h2>
					{/* Posts back to this page to render the review step (progressive
					    enhancement-free): no JS needed for the confirmation screen. */}
					<form method="POST">
						<input type="hidden" name="slotStart" value={activeSlot!.start} />

						<div class="form-field">
							<label for="customerNumber">{t('booking.form.customerNumber')}</label>
							<input id="customerNumber" name="customerNumber" type="text" maxlength="50" value={fv.customerNumber ?? ''} />
						</div>
						<fieldset class="form-field">
							<legend>{t('booking.form.firstVisit')} <span class="req">({t('booking.form.required')})</span></legend>
							<label class="radio"><input type="radio" name="firstVisit" value="new" required checked={(fv.firstVisit ?? 'new') === 'new'} /> {t('booking.form.firstVisitNew')}</label>
							<label class="radio"><input type="radio" name="firstVisit" value="returning" checked={fv.firstVisit === 'returning'} /> {t('booking.form.firstVisitReturning')}</label>
						</fieldset>
						<div class="form-field">
							<label for="name">{t('booking.form.name')} <span class="req">({t('booking.form.required')})</span></label>
							<input id="name" name="name" type="text" required maxlength="100" value={fv.name ?? ''} />
						</div>
						<div class="form-field">
							<label for="nameKana">{t('booking.form.nameKana')}</label>
							<input id="nameKana" name="nameKana" type="text" maxlength="100" value={fv.nameKana ?? ''} />
						</div>
						<fieldset class="form-field">
							<legend>{t('booking.form.gender')} <span class="req">({t('booking.form.required')})</span></legend>
							<label class="radio"><input type="radio" name="gender" value="female" required checked={fv.gender === 'female'} /> {t('booking.form.genderFemale')}</label>
							<label class="radio"><input type="radio" name="gender" value="male" checked={fv.gender === 'male'} /> {t('booking.form.genderMale')}</label>
						</fieldset>
						<div class="form-field">
							<label for="dateOfBirth">{t('booking.form.dateOfBirth')} <span class="req">({t('booking.form.required')})</span></label>
							<input id="dateOfBirth" name="dateOfBirth" type="date" required value={fv.dateOfBirth ?? ''} />
						</div>
						<div class="form-field">
							<label for="email">{t('booking.form.email')} <span class="req">({t('booking.form.required')})</span></label>
							<input id="email" name="email" type="email" required maxlength="200" value={fv.email ?? ''} />
						</div>
						<div class="form-field">
							<label for="phone">{t('booking.form.phone')} <span class="req">({t('booking.form.required')})</span></label>
							<input id="phone" name="phone" type="tel" required maxlength="40" value={fv.phone ?? ''} />
						</div>
						<div class="form-field">
							<label for="postalCode">{t('booking.form.postalCode')} <span class="req">({t('booking.form.required')})</span></label>
							<input id="postalCode" name="postalCode" type="text" required maxlength="20" value={fv.postalCode ?? ''} />
						</div>
						<div class="form-field">
							<label for="prefecture">{t('booking.form.prefecture')} <span class="req">({t('booking.form.required')})</span></label>
							<select id="prefecture" name="prefecture" required>
								<option value="" selected={!fv.prefecture}>{t('booking.form.choose')}</option>
								{PREFECTURES.map((p) => (
									<option value={p} selected={p === fv.prefecture}>{p}</option>
								))}
							</select>
						</div>
						<div class="form-field">
							<label for="address">{t('booking.form.address')} <span class="req">({t('booking.form.required')})</span></label>
							<input id="address" name="address" type="text" required maxlength="200" value={fv.address ?? ''} />
						</div>
						<div class="form-field">
							<label for="locale">{t('booking.form.language')}</label>
							<select id="locale" name="locale">
								{LOCALES.map((l) => (
									<option value={l} selected={l === (fv.locale ?? locale)}>{LOCALE_NAMES[l]}</option>
								))}
							</select>
						</div>
						<p style="font-size:0.85rem;color:var(--muted)">{t('booking.form.consent')}</p>
						<button class="btn btn-primary" type="submit">{t('booking.form.review')}</button>
					</form>
				</div>
			) : (
				<div>
					{days.length === 0 && <p>{t('booking.noSlots')}</p>}

					{days.length > 0 && (
						<div class="calendar">
							<h2 class="section-title">{t('booking.selectDate')}</h2>

							{/* Enhanced flatpickr widget — shown via the `.js` class (set in
							    <head> before paint) so there's no flash; the script only
							    attaches the picker. */}
							<div class="cal-enhanced">
								<input
									id="calendar-widget"
									type="text"
									readonly
									class="cal-input"
									placeholder={t('booking.selectDate')}
									value={selectedDate ?? ''}
									data-enable={JSON.stringify([...availableDates])}
									data-base={reservationPath}
									data-selected={selectedDate ?? ''}
								/>
							</div>

							{/* No-JS fallback: server-rendered month grid. */}
							<div class="cal-fallback">
							{months.map((month) => (
								<div class="cal-month">
									<h3 class="cal-title">{formatMonthYear(month.anchorDate, locale)}</h3>
									<div class="cal-grid cal-head">
										{weekdayKeys.map((k) => (
											<span class="cal-weekday">{t(`hours.days.${k}`)}</span>
										))}
									</div>
									{month.weeks.map((week) => (
										<div class="cal-grid">
											{week.map((cell) =>
												!cell ? (
													<span class="cal-cell cal-empty" />
												) : cell.available ? (
													<a
														class:list={['cal-cell', 'cal-day', { 'cal-selected': cell.date === selectedDate }]}
														href={`${reservationPath}?date=${cell.date}`}
														aria-current={cell.date === selectedDate ? 'date' : undefined}
													>
														{cell.day}
													</a>
												) : (
													<span class="cal-cell cal-disabled">{cell.day}</span>
												),
											)}
										</div>
									))}
								</div>
							))}
							</div>
							<p class="cal-hint">{t('hours.amLabel')} · {t('hours.pmLabel')}</p>
						</div>
					)}

					{/* Every day's slots are rendered up front; the active one is shown
					    via `.is-active`. The server sets it from ?date= (no-JS / direct
					    link); with JS the script toggles it on date pick, so changing
					    date never reloads the page (no header flicker, no SSR). */}
					{days.length > 0 && (
						<div class:list={['slot-area', { 'has-active': selectedDate }]}>
							<h2 class="section-title">{t('booking.selectSlot')}</h2>
							{days.map((day) => (
								<div
									class:list={['day-block', 'slot-group', { 'is-active': day.date === selectedDate }]}
									data-date={day.date}
								>
									<h3>{formatDateLong(`${day.date}T00:00`, locale)}</h3>
									<div class="slot-grid">
										{day.slots.map((slot) => (
											<a class="slot" href={`${reservationPath}?slot=${slot.start}`}>
												{slot.time}
											</a>
										))}
									</div>
								</div>
							))}
						</div>
					)}
				</div>
			)
		}
	</section>

	<script>
		import flatpickr from 'flatpickr';
		import 'flatpickr/dist/flatpickr.css';

		const input = document.getElementById('calendar-widget');
		if (input instanceof HTMLInputElement) {
			const enable: string[] = JSON.parse(input.dataset.enable || '[]');
			const base = input.dataset.base || '';
			const selected = input.dataset.selected || undefined;

			const slotArea = document.querySelector('.slot-area');
			const groups = Array.from(document.querySelectorAll<HTMLElement>('.slot-group'));

			// Reveal a day's slots without navigating — no SSR reload, no flicker.
			// The URL is kept in sync via replaceState so refresh/share still works.
			const showDate = (dateStr: string) => {
				for (const g of groups) g.classList.toggle('is-active', g.dataset.date === dateStr);
				slotArea?.classList.toggle('has-active', Boolean(dateStr));
				history.replaceState(null, '', dateStr ? `${base}?date=${dateStr}` : base);
			};

			flatpickr(input, {
				enable,
				defaultDate: selected,
				minDate: enable[0],
				maxDate: enable[enable.length - 1],
				disableMobile: true,
				onChange: (_dates, dateStr) => {
					if (dateStr) showDate(dateStr);
				},
			});
		}

		// On the "change time" link, prefer the browser Back button so we return
		// to the calendar with its state/scroll intact (no reload). Falls back to
		// the href (?date=…) when there's no history to go back to, or when the
		// form was reached via an "edit" POST (data-back="false") — there, going
		// back would land on the review POST and trigger a resubmission prompt.
		const changeSlot = document.querySelector<HTMLAnchorElement>('.change-slot');
		changeSlot?.addEventListener('click', (event) => {
			if (changeSlot.dataset.back !== 'false' && history.length > 1) {
				event.preventDefault();
				history.back();
			}
		});
	</script>

	<style>
		.review-actions {
			display: flex;
			flex-wrap: wrap;
			gap: 12px;
			align-items: center;
		}
		.review-actions form {
			margin: 0;
		}
	</style>
</Base>
