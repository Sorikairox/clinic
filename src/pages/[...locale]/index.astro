---
import Base from '@/layouts/Base.astro';
import HoursTable from '@/components/HoursTable.astro';
import { localizedPath, resolveLocale, useTranslations } from '@/i18n/utils';
import { clinicJsonLd } from '@/lib/seo';

const locale = resolveLocale(Astro.params.locale);
if (!locale) return new Response('Not Found', { status: 404 });
const t = useTranslations(locale);
const jsonLd = clinicJsonLd(locale, (Astro.site ?? new URL('https://clinic.example.com')).href);

const services = [
	{ key: 'gastroenterology', img: '/images/service-gastroenterology.jpg' },
	{ key: 'proctology', img: '/images/service-proctology.jpg' },
	{ key: 'vaccines', img: '/images/service-vaccine.jpg' },
	{ key: 'tv', img: '/images/service-tv.jpg' },
];
---

<Base
	{locale}
	canonical="/"
	title={t('home.metaTitle')}
	description={t('home.metaDescription')}
	{jsonLd}
>
	<section class="hero">
		<h1>{t('home.heroTitle')}</h1>
		<p>{t('home.heroSubtitle')}</p>
		<a class="btn btn-primary" href={localizedPath('/reservation', locale)}>{t('home.heroCta')}</a>
	</section>

	<section>
		<h2 class="section-title">{t('home.introHeading')}</h2>
		<p class="lead">{t('home.introBody')}</p>
	</section>

	<section>
		<div class="callout">
			<h2 style="margin-top:0">{t('home.foreignHeading')}</h2>
			<p style="margin-bottom:0">{t('home.foreignBody')}</p>
		</div>
	</section>

	<section>
		<h2 class="section-title">{t('home.servicesHeading')}</h2>
		<div class="card-grid">
			{
				services.map((s) => (
					<a class="card media-card" href={localizedPath('/services', locale)}>
						<img src={s.img} alt={t(`services.${s.key}.imageAlt`)} loading="lazy" />
						<div class="media-card-body">
							<h3>{t(`services.${s.key}.title`)}</h3>
							<p>{t(`services.${s.key}.summary`)}</p>
							<span class="card-link">{t('common.readMore')} →</span>
						</div>
					</a>
				))
			}
		</div>
	</section>

	<section>
		<h2 class="section-title">{t('home.hoursHeading')}</h2>
		<HoursTable {locale} />
	</section>

	<section>
		<h2 class="section-title">{t('home.accessHeading')}</h2>
		<table class="info-table">
			<tbody>
				<tr><th>{t('access.addressLabel')}</th><td>{t('access.address')}</td></tr>
				<tr><th>{t('access.phoneLabel')}</th><td><a href="tel:+81364539307">{t('access.phone')}</a></td></tr>
			</tbody>
		</table>
		<p style="margin-top:16px">
			<a href={localizedPath('/access', locale)}>{t('common.readMore')} →</a>
		</p>
	</section>
</Base>
