---
import Base from '@/layouts/Base.astro';
import { resolveLocale, useTranslations } from '@/i18n/utils';

const locale = resolveLocale(Astro.params.locale);
if (!locale) return new Response('Not Found', { status: 404 });
const t = useTranslations(locale);

const items = [
	{ key: 'anoscope', img: '/images/facility-anoscope.jpg' },
	{ key: 'endoscope', img: '/images/facility-endoscope.jpg' },
	{ key: 'xray', img: '/images/facility-xray.jpg' },
	{ key: 'ultrasound', img: '/images/facility-ultrasound.jpg' },
	{ key: 'recovery', img: '/images/facility-recovery.jpg' },
	{ key: 'sterilizer', img: '/images/facility-sterilizer.jpg' },
	{ key: 'aed', img: '/images/facility-aed.jpg' },
	{ key: 'airPurifier', img: '/images/facility-air-purifier.jpg' },
];
---

<Base
	{locale}
	canonical="/facility"
	title={t('facility.metaTitle')}
	description={t('facility.metaDescription')}
>
	<section>
		<h1 class="section-title">{t('facility.heading')}</h1>
		<p class="lead">{t('facility.intro')}</p>
	</section>

	<section>
		<div class="facility-grid">
			{
				items.map((item) => (
					<figure class="facility-card">
						<img src={item.img} alt={t(`facility.items.${item.key}.title`)} loading="lazy" />
						<figcaption>
							<h3>{t(`facility.items.${item.key}.title`)}</h3>
							<p>{t(`facility.items.${item.key}.body`)}</p>
						</figcaption>
					</figure>
				))
			}
		</div>
	</section>
</Base>

<style>
	.facility-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 20px;
	}
	.facility-card {
		margin: 0;
		background: var(--white);
		border: 1px solid var(--line);
		border-radius: var(--radius);
		overflow: hidden;
	}
	.facility-card img {
		width: 100%;
		height: 180px;
		object-fit: cover;
		display: block;
		border-bottom: 1px solid var(--line);
	}
	.facility-card figcaption {
		padding: 16px 20px 20px;
	}
	.facility-card h3 {
		margin: 0 0 8px;
		font-size: 1.05rem;
	}
	.facility-card p {
		margin: 0;
		color: var(--muted);
		font-size: 0.95rem;
	}
</style>
