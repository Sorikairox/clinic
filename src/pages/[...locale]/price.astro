---
import Base from '@/layouts/Base.astro';
import { resolveLocale, useItems, useTranslations } from '@/i18n/utils';

const locale = resolveLocale(Astro.params.locale);
if (!locale) return new Response('Not Found', { status: 404 });
const t = useTranslations(locale);
const items = useItems<{ label: string; price: string }>(locale);
const selfPay = items('price.selfPay');
const vaccines = items('price.vaccines');
---

<Base
	{locale}
	canonical="/price"
	title={t('price.metaTitle')}
	description={t('price.metaDescription')}
>
	<section>
		<h1 class="section-title">{t('price.heading')}</h1>
		<p class="lead">{t('price.intro')}</p>
	</section>

	<section>
		<h2 class="section-title">{t('price.insuranceHeading')}</h2>
		<div class="callout">
			<p style="margin:0">{t('price.insuranceNote')}</p>
		</div>
	</section>

	<section>
		<h2 class="section-title">{t('price.selfPayHeading')}</h2>
		<table class="info-table price-table">
			<tbody>
				{
					selfPay.map((row) => (
						<tr>
							<th>{row.label}</th>
							<td>{row.price}</td>
						</tr>
					))
				}
			</tbody>
		</table>
		<p class="price-note">{t('price.selfPayNote')}</p>
	</section>

	<section>
		<h2 class="section-title">{t('price.vaccineHeading')}</h2>
		<table class="info-table price-table">
			<tbody>
				{
					vaccines.map((row) => (
						<tr>
							<th>{row.label}</th>
							<td>{row.price}</td>
						</tr>
					))
				}
			</tbody>
		</table>
		<p class="price-note">{t('price.vaccineNote')}</p>
	</section>

	<section>
		<div class="prose">
			<p>{t('price.note')}</p>
		</div>
	</section>
</Base>

<style>
	.price-table th {
		width: 70%;
		color: var(--ink);
		font-weight: 500;
	}
	.price-table td {
		text-align: right;
		white-space: nowrap;
		font-weight: 600;
		color: var(--teal-dark);
	}
	.price-note {
		font-size: 0.9rem;
		color: var(--muted);
		margin-top: 10px;
	}
</style>
