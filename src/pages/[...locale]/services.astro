---
import Base from '@/layouts/Base.astro';
import { resolveLocale, useList, useTranslations } from '@/i18n/utils';

const locale = resolveLocale(Astro.params.locale);
if (!locale) return new Response('Not Found', { status: 404 });
const t = useTranslations(locale);
const list = useList(locale);
const gastroConditions = list('services.gastroenterology.conditions');
const proctoConditions = list('services.proctology.conditions');
---

<Base
	{locale}
	canonical="/services"
	title={t('services.metaTitle')}
	description={t('services.metaDescription')}
>
	<section>
		<h1 class="section-title">{t('services.heading')}</h1>
		<p class="lead">{t('services.intro')}</p>
	</section>

	<section class="service-block">
		<img class="service-img" src="/images/service-gastroenterology.jpg" alt={t('services.gastroenterology.imageAlt')} loading="lazy" />
		<div class="prose">
			<h2 class="section-title">{t('services.gastroenterology.title')}</h2>
			<p>{t('services.gastroenterology.body')}</p>
			<h3>{t('services.gastroenterology.conditionsHeading')}</h3>
			<ul>
				{gastroConditions.map((c) => <li>{c}</li>)}
			</ul>
			<h3>{t('services.gastroenterology.endoscopyHeading')}</h3>
			<p>{t('services.gastroenterology.endoscopy')}</p>
		</div>
	</section>

	<section class="service-block">
		<img class="service-img" src="/images/service-proctology.jpg" alt={t('services.proctology.imageAlt')} loading="lazy" />
		<div class="prose">
			<h2 class="section-title">{t('services.proctology.title')}</h2>
			<p>{t('services.proctology.body')}</p>
			<h3>{t('services.proctology.conditionsHeading')}</h3>
			<ul>
				{proctoConditions.map((c) => <li>{c}</li>)}
			</ul>
		</div>
	</section>

	<section class="service-block">
		<img class="service-img" src="/images/service-vaccine.jpg" alt={t('services.vaccines.imageAlt')} loading="lazy" />
		<div class="prose">
			<h2 class="section-title">{t('services.vaccines.title')}</h2>
			<p>{t('services.vaccines.body')}</p>
		</div>
	</section>

	<section class="service-block">
		<img class="service-img" src="/images/service-tv.jpg" alt={t('services.tv.imageAlt')} loading="lazy" />
		<div class="prose">
			<h2 class="section-title">{t('services.tv.title')}</h2>
			<p>{t('services.tv.body')}</p>
		</div>
	</section>
</Base>

<style>
	.service-block {
		display: grid;
		grid-template-columns: 280px 1fr;
		gap: 28px;
		align-items: start;
	}
	.service-img {
		width: 100%;
		height: 200px;
		object-fit: cover;
		border-radius: var(--radius);
		border: 1px solid var(--line);
	}
	.service-block .prose h2 {
		margin-top: 0;
	}
	@media (max-width: 640px) {
		.service-block {
			grid-template-columns: 1fr;
		}
	}
</style>
