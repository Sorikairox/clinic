---
import { actions } from 'astro:actions';
import Base from '@/layouts/Base.astro';
import AdminLangSwitcher from '@/components/AdminLangSwitcher.astro';
import { useTranslations } from '@/i18n/utils';
import { resolveAdminLocale } from '@/lib/adminLocale';
import { getSessionStaff } from '@/lib/session';

const locale = resolveAdminLocale(Astro.cookies, Astro.url);
const t = useTranslations(locale);

if (await getSessionStaff(Astro.cookies)) return Astro.redirect('/admin');

const result = Astro.getActionResult(actions.login);
if (result && !result.error) return Astro.redirect('/admin');
const error = result?.error ? t('admin.login.error') : '';
---

<Base
	{locale}
	canonical="/admin/login"
	title={t('admin.login.heading')}
	description="Staff login"
	hideNav={true}
	noindex={true}
>
	<div class="admin-wrap" style="max-width:420px;margin:40px auto;">
		<div style="display:flex;justify-content:flex-end;margin-bottom:8px">
			<AdminLangSwitcher {locale} action="/admin/login" />
		</div>
		<h1 class="section-title">{t('admin.login.heading')}</h1>
		{error && <div class="error-banner">{error}</div>}
		<form method="POST" action={actions.login}>
			<div class="form-field">
				<label for="email">{t('admin.login.email')}</label>
				<input id="email" name="email" type="email" required autocomplete="username" />
			</div>
			<div class="form-field">
				<label for="password">{t('admin.login.password')}</label>
				<input id="password" name="password" type="password" required autocomplete="current-password" />
			</div>
			<button class="btn btn-primary" type="submit">{t('admin.login.submit')}</button>
		</form>
	</div>
</Base>
