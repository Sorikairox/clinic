---
import { LOCALES, LOCALE_NAMES, type Locale } from '@/i18n/config';

interface Props {
	locale: Locale;
	/** Where the GET form submits (e.g. "/admin" or "/admin/login"). */
	action: string;
	/** Preserve the selected slot-manager day across a language change. */
	manageDate?: string;
}

const { locale, action, manageDate } = Astro.props;
---

<form method="GET" action={action} class="admin-lang">
	{manageDate && <input type="hidden" name="manageDate" value={manageDate} />}
	<select name="lang" aria-label="Display language" data-admin-lang>
		{LOCALES.map((l) => (
			<option value={l} selected={l === locale}>{LOCALE_NAMES[l]}</option>
		))}
	</select>
	{/* No-JS fallback only: submit the choice. Rendered solely when scripting is
	    off, so it never becomes a second submit button in the JS DOM (with JS the
	    select auto-submits, and a stray submit button would shadow the page's own
	    login/logout button). */}
	<noscript><button class="btn btn-outline btn-sm" type="submit">OK</button></noscript>
</form>

<script>
	// Auto-submit the language switcher on change.
	const select = document.querySelector<HTMLSelectElement>('select[data-admin-lang]');
	select?.addEventListener('change', () => select.form?.submit());
</script>
