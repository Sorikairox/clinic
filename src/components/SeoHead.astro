---
import { LOCALE_TAGS, type Locale } from '@/i18n/config';
import { alternateLinks, localizedPath } from '@/i18n/utils';

interface Props {
	locale: Locale;
	canonical: string; // locale-less canonical path, e.g. "/director"
	title: string;
	description: string;
	jsonLd?: unknown;
	noindex?: boolean;
}

const { locale, canonical, title, description, jsonLd, noindex } = Astro.props;
const site = Astro.site ?? new URL('https://clinic.example.com');
const abs = (path: string) => new URL(path, site).href;
const canonicalUrl = abs(localizedPath(canonical, locale));
const alternates = noindex ? [] : alternateLinks(canonical);
---

<title>{title}</title>
<meta name="description" content={description} />
{noindex && <meta name="robots" content="noindex, nofollow" />}
{!noindex && <link rel="canonical" href={canonicalUrl} />}
{alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={abs(a.path)} />)}
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:locale" content={LOCALE_TAGS[locale]} />
<meta property="og:site_name" content="Shiba Coloproctological Clinic" />
<meta name="twitter:card" content="summary_large_image" />
{jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
