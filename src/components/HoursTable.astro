---
import { type Locale } from '@/i18n/config';
import { useTranslations } from '@/i18n/utils';
import { HOURS_DAYS, HOURS_GRID, HOURS_SYMBOL } from '@/lib/hours';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<div class="hours-wrap">
	<table class="info-table hours-table">
		<thead>
			<tr>
				<th>{t('hours.colTime')}</th>
				{HOURS_DAYS.map((d) => <th class="hours-day">{t(`hours.days.${d}`)}</th>)}
			</tr>
		</thead>
		<tbody>
			<tr>
				<th>{t('hours.amLabel')}</th>
				{HOURS_DAYS.map((d) => <td class="hours-cell">{HOURS_SYMBOL[HOURS_GRID.morning[d]]}</td>)}
			</tr>
			<tr>
				<th>{t('hours.pmLabel')}</th>
				{HOURS_DAYS.map((d) => <td class="hours-cell">{HOURS_SYMBOL[HOURS_GRID.afternoon[d]]}</td>)}
			</tr>
		</tbody>
	</table>
	<p class="hours-legend">
		<span>{t('hours.legendOpen')}</span>
		<span>{t('hours.legendAppointment')}</span>
		<span>{t('hours.legendClosed')}</span>
	</p>
	<p class="hours-note">{t('hours.closedNote')}</p>
	<p class="hours-note">{t('hours.appointmentNote')}</p>
</div>

<style>
	.hours-table th,
	.hours-table td {
		text-align: center;
	}
	.hours-table thead th,
	.hours-table tbody th {
		color: var(--muted);
	}
	.hours-table tbody th {
		text-align: left;
		width: auto;
		white-space: nowrap;
	}
	.hours-day {
		width: 9%;
	}
	.hours-cell {
		font-size: 1.1rem;
		font-weight: 600;
		color: var(--teal-dark);
	}
	.hours-legend {
		display: flex;
		flex-wrap: wrap;
		gap: 16px;
		font-size: 0.9rem;
		color: var(--muted);
		margin: 12px 0 4px;
	}
	.hours-note {
		font-size: 0.9rem;
		color: var(--muted);
		margin: 4px 0 0;
	}
</style>
