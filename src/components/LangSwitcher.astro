---
import { LOCALES, LOCALE_NAMES, type Locale } from '@/i18n/config';
import { localizedPath, useTranslations } from '@/i18n/utils';

interface Props {
	locale: Locale;
	canonical: string;
}

const { locale, canonical } = Astro.props;
const t = useTranslations(locale);
---

<details class="lang-switcher">
	<summary aria-label={t('common.languageLabel')}>🌐 {LOCALE_NAMES[locale]}</summary>
	<ul>
		{
			LOCALES.map((l) => (
				<li>
					<a
						href={localizedPath(canonical, l)}
						hreflang={l}
						aria-current={l === locale ? 'true' : undefined}
					>
						{LOCALE_NAMES[l]}
					</a>
				</li>
			))
		}
	</ul>
</details>
