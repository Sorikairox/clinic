---
import { type Locale } from '@/i18n/config';
import { localizedPath, useTranslations } from '@/i18n/utils';
import { NAV_ITEMS } from '@/lib/routes';
import LangSwitcher from './LangSwitcher.astro';

interface Props {
	locale: Locale;
	canonical: string;
}

const { locale, canonical } = Astro.props;
const t = useTranslations(locale);
---

<header class="site-header">
	<div class="container header-inner">
		<a class="brand" href={localizedPath('/', locale)}>
			<img class="brand-logo" src="/images/logo.png" alt={t('site.name')} width="160" height="40" />
		</a>
		<button
			type="button"
			class="nav-toggle"
			aria-label={t('common.menu')}
			aria-controls="main-nav"
			aria-expanded="false"
		>
			<span class="nav-toggle-bars" aria-hidden="true"></span>
		</button>
		<nav id="main-nav" class="main-nav" aria-label="Main navigation">
			{
				NAV_ITEMS.map((item) => (
					<a
						href={localizedPath(item.path, locale)}
						aria-current={canonical === item.path ? 'page' : undefined}
					>
						{t(item.labelKey)}
					</a>
				))
			}
		</nav>
		<div class="header-actions">
			<LangSwitcher {locale} {canonical} />
			<a class="btn btn-primary" href={localizedPath('/reservation', locale)}>{t('nav.book')}</a>
		</div>
	</div>
</header>

<script>
	const header = document.querySelector<HTMLElement>('.site-header');
	const toggle = header?.querySelector<HTMLButtonElement>('.nav-toggle');
	const nav = document.getElementById('main-nav');

	if (header && toggle && nav) {
		// Mark as JS-enhanced so the collapsible burger behaviour kicks in.
		// Without JS the full nav stays visible (the no-JS fallback).
		header.classList.add('nav-enhanced');

		const setOpen = (open: boolean) => {
			header.classList.toggle('nav-open', open);
			toggle.setAttribute('aria-expanded', String(open));
		};

		toggle.addEventListener('click', () => {
			setOpen(!header.classList.contains('nav-open'));
		});

		// Collapse after picking a destination.
		nav.addEventListener('click', (event) => {
			if ((event.target as HTMLElement).closest('a')) setOpen(false);
		});

		// Close on Escape for keyboard users.
		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape' && header.classList.contains('nav-open')) {
				setOpen(false);
				toggle.focus();
			}
		});
	}
</script>
