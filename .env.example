# Public site URL (used for canonical URLs, hreflang and the sitemap)
SITE_URL=https://clinic.example.com

# Database — local dev defaults to a SQLite file if unset.
# For production, point these at a Turso (libSQL) database:
DATABASE_URL=file:./local.db
# DATABASE_AUTH_TOKEN=your-turso-token
#
# To exercise the real HTTP/libSQL path locally, run the test DB container
# (see Dockerfile.testdb / docker-compose.yml) and use:
# DATABASE_URL=http://127.0.0.1:8080

# Secret used to sign staff session cookies (use a long random string)
SESSION_SECRET=change-me-to-a-long-random-string

# Resend (https://resend.com) — for confirmation/decline emails.
# If unset, emails are logged instead of sent (dev mode).
# RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=Shiba Clinic <onboarding@resend.dev>

# Google reCAPTCHA Enterprise (score-based, invisible) — bot gate on the booking
# form. Managed in the Google Cloud console (Security › reCAPTCHA). The site key
# is public (loads the client script); the API key + project ID are used
# server-side to create assessments. If the API key/project are unset, the widget
# loads but verification is skipped (dev mode).
# RECAPTCHA_SITE_KEY=6Lxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# RECAPTCHA_PROJECT_ID=shiba-clinic
# RECAPTCHA_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Seed script credentials (npm run db:seed)
SEED_STAFF_EMAIL=staff@shibaclinic.example
SEED_STAFF_PASSWORD=change-me
SEED_STAFF_NAME=Clinic Staff
